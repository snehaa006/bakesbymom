# Supabase — these are PUBLIC client keys (safe to expose, protected by Row Level Security).
# Copy this file to .env.local for local dev, and add the same two vars in your
# Vercel project: Settings → Environment Variables.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
